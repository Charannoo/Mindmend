# Supabase (free): Project Settings → API → URL + service_role key (server only; never in the browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk (backend + publishable key in Frontend HTML)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# OpenRouter — optional; local affirmations work without it
OPENROUTER_API_KEY=

# Optional Redis cache
# REDIS_URL=redis://127.0.0.1:6379

PORT=3000

# Production: public URL of your app (OAuth / redirects). Example:
# BASE_URL=https://mindmend-xxxx.onrender.com
BASE_URL=http://localhost:3000
